{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "ETLBox/ETLBox.csproj",
            "ETLBox.Common/ETLBox.Common.csproj",
            "ETLBox.Primitives/ETLBox.Primitives.csproj",
            "ETLBox.Json/ETLBox.Json.csproj",
            "ETLBox.Kafka/ETLBox.Kafka.csproj",
            "ETLBox.Rest/ETLBox.Rest.csproj",
            "ETLBox.RabbitMq/ETLBox.RabbitMq.csproj",
            "ETLBox.Serialization/ETLBox.Serialization.csproj",
            "ETLBox.AI/ETLBox.AI.csproj",
            "ETLBox.Logging.Database/ETLBox.Logging.Database.csproj",
            "ETLBox.Scripting/ETLBox.Scripting.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "netstandard2.0"
      },
      "filter": "filterConfig.yml"
    },
    {
      "src": [
        {
          "files": [
            "ETLBox.ClickHouse/ETLBox.ClickHouse.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "netstandard2.1"
      },
      "filter": "filterConfig.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "toc.yml",
          "index.md"
        ]
      }
    ],
    "dest": "../_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "ETLBox Documentation",
      "_appFooter": "ETLBox \u2014 It's all in the box",
      "_enableSearch": true
    }
  }
}
